{
  "name": "@sigmalink/voice-mac",
  "version": "0.1.0",
  "private": true,
  "description": "Native macOS Speech.framework recognizer for SigmaLink (BridgeVoice). Falls back to a no-op stub on non-darwin platforms.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "src",
    "binding.gyp",
    "prebuilds",
    "README.md"
  ],
  "scripts": {
    "install": "node-gyp-build",
    "rebuild": "node-gyp rebuild",
    "prebuild": "prebuildify --napi --strip"
  },
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.1"
  },
  "devDependencies": {
    "node-gyp": "^10.2.0",
    "prebuildify": "^6.0.1"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "engines": {
    "node": ">=18"
  }
}
